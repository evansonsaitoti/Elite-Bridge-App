# Server Configuration
NODE_ENV=production
PORT=3000

# Database
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require

# JWT
JWT_SECRET=replace-with-a-random-secret-at-least-32-characters
JWT_EXPIRE=7d

# CORS
CORS_ORIGIN=https://elite-bridge-app-2uc5.vercel.app

# Optional integrations can be added later
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
FIREBASE_PROJECT_ID=
FIREBASE_PRIVATE_KEY=
FIREBASE_CLIENT_EMAIL=
CHEKR_API_KEY=
CHEKR_API_URL=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=
AWS_REGION=

# Frontend URLs
EMPLOYER_APP_URL=https://elite-bridge-app-2uc5.vercel.app
CAREGIVER_APP_URL=
ADMIN_APP_URL=
