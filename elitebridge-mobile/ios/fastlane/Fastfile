default_platform(:ios)

platform :ios do
  before_all do
    setup_ci if ENV["GITHUB_ACTIONS"]
  end

  desc "Push a new beta build to TestFlight"
  lane :beta do
    api_key = app_store_connect_api_key(
      key_id: ENV["APP_STORE_CONNECT_KEY_ID"],
      issuer_id: ENV["APP_STORE_CONNECT_ISSUER_ID"],
      key_filepath: "fastlane/AuthKey_3VCN742K92.p8",
      duration: 1200,
      in_house: false
    )

    # Install CocoaPods
    sh("pod install")

    # Get latest provisioning profile
    profile = get_provisioning_profile(
      api_key: api_key,
      app_identifier: "com.app.elitebridgemobile",
      provisioning_name: "com.app.elitebridgemobile AppStore",
      ignore_profiles_with_different_name: true
    )

    # Get latest build number and increment
    build_num = lane_context[SharedValues::LATEST_TESTFLIGHT_BUILD_NUMBER]
    if build_num.nil?
      begin
        build_num = get_latest_testflight_build_number(api_key: api_key, app_identifier: "com.app.elitebridgemobile")
      rescue
        build_num = 0
      end
    end
    increment_build_number(build_number: build_num + 1)

    # Build the app with explicit profile mapping
    build_app(
      workspace: "EliteBridgeAdmin.xcodeproj/project.xcworkspace",
      scheme: "EliteBridgeAdmin",
      export_method: "app-store",
      output_directory: "./build",
      output_name: "EliteBridgeApp.ipa",
      clean: true,
      xcargs: "DEVELOPMENT_TEAM=F42HSPN3W4 CODE_SIGN_STYLE=Manual",
      export_options: {
        method: "app-store",
        provisioningProfiles: {
          "com.app.elitebridgemobile" => profile
        }
      }
    )

    # Upload to TestFlight
    upload_to_testflight(
      api_key: api_key,
      app_identifier: "com.app.elitebridgemobile",
      ipa: "./build/EliteBridgeApp.ipa",
      skip_waiting_for_build_processing: true
    )
  end
end
