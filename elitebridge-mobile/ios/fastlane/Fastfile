default_platform(:ios)

platform :ios do
  before_all do
    setup_ci if ENV["GITHUB_ACTIONS"]
  end

  desc "Update app metadata in App Store Connect"
  lane :update_metadata do
    api_key = app_store_connect_api_key(
      key_id: ENV["APP_STORE_CONNECT_KEY_ID"],
      issuer_id: ENV["APP_STORE_CONNECT_ISSUER_ID"],
      key_filepath: "fastlane/AuthKey_3VCN742K92.p8"
    )

    deliver(
      api_key: api_key,
      app_identifier: "com.app.elitebridgemobile",
      privacy_url: {
        "default" => "http://34.75.156.104:8080/privacy.html"
      },
      skip_screenshots: true,
      skip_metadata: false,
      edit_live: false
    )
  end

  desc "Push a new beta build to TestFlight"
  lane :beta do
    api_key = app_store_connect_api_key(
      key_id: ENV["APP_STORE_CONNECT_KEY_ID"],
      issuer_id: ENV["APP_STORE_CONNECT_ISSUER_ID"],
      key_filepath: "fastlane/AuthKey_3VCN742K92.p8",
      duration: 1200,
      in_house: false
    )

    # Install CocoaPods
    cocoapods

    # Build the app
    build_app(
      workspace: "EliteBridgeAdmin.xcodeproj/project.xcworkspace",
      scheme: "EliteBridgeAdmin",
      export_method: "app-store",
      output_directory: "./build",
      output_name: "EliteBridgeApp.ipa"
    )

    # Upload to TestFlight
    upload_to_testflight(
      api_key: api_key,
      app_identifier: "com.app.elitebridgemobile",
      ipa: "./build/EliteBridgeApp.ipa",
      skip_waiting_for_build_processing: true
    )
  end
end
