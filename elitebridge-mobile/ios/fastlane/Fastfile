# GitHub Actions imports the Apple Distribution certificate before this lane runs.
# Fastlane handles provisioning and TestFlight upload directly; Expo/EAS is not used for deployment.
default_platform(:ios)

IOS_APP_IDENTIFIER = "com.app.elitebridgemobile"
APPLE_DEVELOPER_TEAM_ID = "F42HSPN3W4"
IOS_VERSION = "1.0.0"
CI_PROVISIONING_PROFILE_NAME = "EliteBridgeAdmin AppStore CI"

platform :ios do
  private_lane :app_store_api_key do
    app_store_connect_api_key(
      key_id: ENV.fetch("APP_STORE_CONNECT_KEY_ID"),
      issuer_id: ENV.fetch("APP_STORE_CONNECT_ISSUER_ID"),
      key_filepath: ENV.fetch("APP_STORE_CONNECT_KEY_PATH"),
      duration: 1200,
      in_house: false
    )
  end

  desc "Build, sign, and upload a new beta build to TestFlight"
  lane :beta do
    api_key = app_store_api_key
    team_id = ENV.fetch("APPLE_TEAM_ID", APPLE_DEVELOPER_TEAM_ID)

    get_provisioning_profile(
      api_key: api_key,
      app_identifier: IOS_APP_IDENTIFIER,
      team_id: team_id,
      force: true,
      provisioning_name: CI_PROVISIONING_PROFILE_NAME,
      ignore_profiles_with_different_name: true,
      cert_owner_name: "Evanson Saitoti",
      filename: "EliteBridgeAdmin_CI.mobileprovision",
      skip_install: false
    )

    profile_name = lane_context[SharedValues::SIGH_NAME]
    UI.user_error!("Fastlane did not return a provisioning profile name") if profile_name.to_s.empty?

    latest_build = latest_testflight_build_number(
      api_key: api_key,
      app_identifier: IOS_APP_IDENTIFIER,
      version: IOS_VERSION,
      initial_build_number: 0
    )
    next_build = latest_build + 1

    increment_build_number(
      xcodeproj: "EliteBridgeAdmin.xcodeproj",
      build_number: next_build
    )
    set_info_plist_value(
      path: "EliteBridgeAdmin/Info.plist",
      key: "CFBundleVersion",
      value: next_build.to_s
    )

    build_app(
      workspace: "EliteBridgeAdmin.xcworkspace",
      scheme: "EliteBridgeAdmin",
      configuration: "Release",
      clean: true,
      export_method: "app-store",
      output_directory: "./build",
      output_name: "EliteBridgeAdmin.ipa",
      codesigning_identity: "Apple Distribution",
      skip_profile_detection: true,
      export_options: {
        method: "app-store",
        signingStyle: "manual",
        teamID: team_id,
        provisioningProfiles: {
          IOS_APP_IDENTIFIER => profile_name
        }
      },
      xcargs: "DEVELOPMENT_TEAM=#{team_id} CODE_SIGN_STYLE=Manual CODE_SIGN_IDENTITY='Apple Distribution' PROVISIONING_PROFILE_SPECIFIER='#{profile_name}'"
    )

    upload_to_testflight(
      api_key: api_key,
      app_identifier: IOS_APP_IDENTIFIER,
      ipa: "./build/EliteBridgeAdmin.ipa",
      skip_waiting_for_build_processing: true
    )
  end
end
